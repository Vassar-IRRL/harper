<?xml version="1.0"?>
<robot name="harper_arm">

  <!-- Materials -->
  <material name="ABS_Plastic">
    <color rgba="0.965 0.965 0.953 1.0"/>
  </material>

  <link name="base_link">
    <inertial>
      <origin xyz="0.029187 0.026141 0.016333" rpy="0 0 0"/>
      <mass value="0.216148"/>
      <inertia ixx="1.911689e-04" ixy="1.217393e-06" ixz="6.875221e-07"
               iyy="3.586378e-04" iyz="1.276434e-05" izz="4.108880e-04"/>
    </inertial>
    <visual>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/base_link.dae" scale="1 1 1"/>
      </geometry>
      <material name="ABS_Plastic"/>
    </visual>
    <collision>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/base_link_collision.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <link name="ubracket_link">
    <inertial>
      <origin xyz="-0.001692 -0.016243 0.000000" rpy="0 0 0"/>
      <mass value="0.056802"/>
      <inertia ixx="2.770726e-05" ixy="-1.975149e-06" ixz="1.073252e-13"
               iyy="5.139242e-05" iyz="-1.551957e-13" izz="5.866256e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.127800 0.002450 -0.136700" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/ubracket_link.dae" scale="1 1 1"/>
      </geometry>
      <material name="ABS_Plastic"/>
    </visual>
    <collision>
      <origin xyz="-0.127800 0.002450 -0.136700" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/ubracket_link_collision.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <link name="abduction_link">
    <inertial>
      <origin xyz="0.033769 0.000011 -0.020333" rpy="0 0 0"/>
      <mass value="0.170550"/>
      <inertia ixx="1.127913e-04" ixy="-4.833191e-09" ixz="5.136684e-06"
               iyy="1.389815e-04" iyz="6.006518e-08" izz="7.305519e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.093300 0.039250 -0.136700" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/abduction_link.dae" scale="1 1 1"/>
      </geometry>
      <material name="ABS_Plastic"/>
    </visual>
    <collision>
      <origin xyz="-0.093300 0.039250 -0.136700" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/abduction_link_collision.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <link name="shoulder_rot_link">
    <inertial>
      <origin xyz="0.048728 -0.078593 -0.074581" rpy="0 0 0"/>
      <mass value="0.470274"/>
      <inertia ixx="9.964337e-04" ixy="1.649744e-05" ixz="2.954947e-05"
               iyy="1.023795e-03" iyz="-2.257510e-04" izz="4.815695e-04"/>
    </inertial>
    <visual>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/shoulder_rot_link.dae" scale="1 1 1"/>
      </geometry>
      <material name="ABS_Plastic"/>
    </visual>
    <collision>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/shoulder_rot_link_collision.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <link name="elbow_forearm_link">
    <inertial>
      <origin xyz="0.042958 -0.002857 0.080307" rpy="0 0 0"/>
      <mass value="0.623764"/>
      <inertia ixx="2.469378e-03" ixy="-2.608289e-06" ixz="-6.585970e-05"
               iyy="2.472785e-03" iyz="-1.032511e-04" izz="4.512478e-04"/>
    </inertial>
    <visual>
      <origin xyz="0.041000 0.152500 -0.012500" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/elbow_forearm_link.dae" scale="1 1 1"/>
      </geometry>
      <material name="ABS_Plastic"/>
    </visual>
    <collision>
      <origin xyz="0.041000 0.152500 -0.012500" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/elbow_forearm_link_collision.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <link name="forearm_front_link">
    <inertial>
      <origin xyz="-0.045198 0.000346 -0.009446" rpy="0 0 0"/>
      <mass value="0.077289"/>
      <inertia ixx="3.638935e-05" ixy="1.519260e-06" ixz="-4.440843e-06"
               iyy="9.483507e-05" iyz="-2.736881e-07" izz="1.067445e-04"/>
    </inertial>
    <visual>
      <origin xyz="-0.161425 -0.000000 0.000000" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/forearm_front_link.dae" scale="1 1 1"/>
      </geometry>
      <material name="ABS_Plastic"/>
    </visual>
    <collision>
      <origin xyz="-0.161425 -0.000000 0.000000" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://harper_arm_description/meshes/harper_arm/forearm_front_link_collision.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="shoulder_flexion_joint" type="revolute">
    <parent link="base_link"/>
    <child link="ubracket_link"/>
    <origin xyz="0.044850 -0.007541 0.039906" rpy="-0.261799 -0.000000 -0.000000"/>
    <axis xyz="-0.000000 1.000000 -0.000000"/>
    <limit lower="-3.141593" upper="1.570796" effort="100.0" velocity="1.00"/>
  </joint>

  <joint name="shoulder_abduction_joint" type="revolute">
    <parent link="ubracket_link"/>
    <child link="abduction_link"/>
    <origin xyz="-0.034700 -0.036800 -0.000000" rpy="-0.000000 0.000000 0.000000"/>
    <axis xyz="-1.000000 0.000000 -0.000000"/>
    <limit lower="-0.261799" upper="3.141593" effort="100.0" velocity="1.00"/>
  </joint>

  <joint name="shoulder_rotation_joint" type="continuous">
    <parent link="abduction_link"/>
    <child link="shoulder_rot_link"/>
    <origin xyz="-0.010250 0.054163 -0.035894" rpy="0.261799 -0.000000 0.000000"/>
    <axis xyz="0.000000 0.258819 0.965926"/>
    <limit effort="100.0" velocity="1.00"/>
  </joint>

  <joint name="elbow_flexion_joint" type="revolute">
    <parent link="shoulder_rot_link"/>
    <child link="elbow_forearm_link"/>
    <origin xyz="0.089014 -0.119601 -0.186783" rpy="3.141593 0.000000 -3.141593"/>
    <axis xyz="1.000000 0.000000 0.000000"/>
    <limit lower="-1.396263" upper="0.610865" effort="100.0" velocity="1.00"/>
  </joint>

  <joint name="forearm_rotation_joint" type="continuous">
    <parent link="elbow_forearm_link"/>
    <child link="forearm_front_link"/>
    <origin xyz="0.041862 0.000337 0.159713" rpy="-2.102137 1.570796 0.000000"/>
    <axis xyz="-1.000000 -0.000000 -0.000000"/>
    <limit effort="100.0" velocity="1.00"/>
  </joint>

  <!-- ROS 2 control: generated generic system -->
  <ros2_control name="harper_arm_system" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
      <param name="cmd_topic">sim/harper_arm_system/cmd</param>
      <param name="state_topic">sim/harper_arm_system/state</param>
    </hardware>

    <joint name="elbow_flexion_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="forearm_rotation_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="shoulder_abduction_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="shoulder_flexion_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="shoulder_rotation_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

</robot>